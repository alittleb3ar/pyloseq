{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Preprocessing and data manipulation\n",
    "\n",
    "**R equivalent:** `subset_samples()`, `prune_taxa()`, `filter_taxa()`,\n",
    "`tax_glom()`, `rarefy_even_depth()`, `transform_sample_counts()`, `merge_samples()`\n",
    "\n",
    "All manipulation functions return **new** `Phyloseq` objects; inputs are never\n",
    "mutated."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pyloseq\n",
    "from pyloseq import (\n",
    "    Phyloseq, OtuTable, SampleData, TaxTable, PhyTree,\n",
    "    subset_samples, prune_taxa, filter_taxa, kOverA,\n",
    "    tax_glom, rarefy_even_depth, transform_sample_counts,\n",
    "    merge_samples, psmelt,\n",
    ")\n",
    "from pyloseq.testing.fixtures import load_global_patterns_reference\n",
    "\n",
    "ref = load_global_patterns_reference()\n",
    "gp = Phyloseq(\n",
    "    otu=OtuTable(ref[\"otu_table\"], taxa_are_rows=True),\n",
    "    sam=SampleData(ref[\"sample_data\"]),\n",
    "    tax=TaxTable(ref[\"tax_table\"]),\n",
    "    tree=PhyTree.from_newick(ref[\"phy_tree_newick\"]),\n",
    ")\n",
    "print(gp)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Subset samples\n",
    "\n",
    "**R equivalent:** `subset_samples(gp, SampleType %in% c(\"Feces\", \"Skin\"))`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "gp_gut = subset_samples(gp, lambda s: s[\"SampleType\"].isin([\"Feces\", \"Skin\"]))\n",
    "print(f\"After subset: {gp_gut.nsamples} samples (was {gp.nsamples})\")\n",
    "assert gp_gut.nsamples < gp.nsamples"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Filter low-abundance taxa\n",
    "\n",
    "**R equivalent:** `filter_taxa(gp, function(x) sum(x > 5) > (0.2 * length(x)), TRUE)`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Keep taxa present with > 5 counts in at least 20% of samples\n",
    "threshold = 0.2 * gp.nsamples\n",
    "gp_filtered = filter_taxa(gp, lambda x: (x > 5).sum() > threshold)\n",
    "print(f\"After filter: {gp_filtered.ntaxa} taxa (was {gp.ntaxa})\")\n",
    "assert gp_filtered.ntaxa < gp.ntaxa"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Agglomerate to Family rank\n",
    "\n",
    "**R equivalent:** `tax_glom(gp, taxrank=\"Family\")`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "gp_family = tax_glom(gp, \"Family\")\n",
    "print(f\"After tax_glom(Family): {gp_family.ntaxa} taxa (was {gp.ntaxa})\")\n",
    "assert gp_family.ntaxa < gp.ntaxa"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Rarefy to even depth\n",
    "\n",
    "**R equivalent:** `rarefy_even_depth(gp, rngseed=42)`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "gp_rare = rarefy_even_depth(gp, rng_seed=42)\n",
    "sample_depths = gp_rare.sample_sums()\n",
    "print(f\"Sample depths after rarefaction: {sample_depths.unique()}\")\n",
    "# All samples should have equal depth\n",
    "assert sample_depths.nunique() == 1, \"Rarefaction should produce equal depths\""
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Relative abundance transformation\n",
    "\n",
    "**R equivalent:** `transform_sample_counts(gp, function(x) x / sum(x))`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "gp_rel = transform_sample_counts(gp, lambda x: x / x.sum())\n",
    "rel_sums = gp_rel.sample_sums()\n",
    "print(f\"Sample sums after relative transform: {rel_sums.round(6).unique()}\")\n",
    "np.testing.assert_allclose(rel_sums.values, 1.0, atol=1e-9)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Melt to tidy format\n",
    "\n",
    "**R equivalent:** `psmelt(gp)`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "melted = psmelt(gp_family)\n",
    "print(melted.shape)\n",
    "print(melted.head())\n",
    "assert \"OTU\" in melted.columns\n",
    "assert \"Abundance\" in melted.columns\n",
    "assert \"Sample\" in melted.columns"
   ]
  }
 ],
